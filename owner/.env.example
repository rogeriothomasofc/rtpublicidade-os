# ============================================================
#  Agency OS — Configuração do Dono do Sistema
#  Copie para owner/.env e preencha com seus dados.
#  NUNCA commite o arquivo owner/.env
# ============================================================

# Seu Supabase (onde ficam as licenças)
OWNER_SUPABASE_URL="https://SEU-PROJECT-REF.supabase.co"
OWNER_SERVICE_ROLE_KEY="sua-service-role-key"

# Access Token da sua conta Supabase
# supabase.com/dashboard/account/tokens
OWNER_SUPABASE_TOKEN="sbp_..."

# ID da sua organização Supabase
# supabase.com/dashboard/org → URL tem o ID
OWNER_ORG_ID="org_xxxxxxxxxx"
