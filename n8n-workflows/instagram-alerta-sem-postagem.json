    {
      "id": "ig-node-05",
      "name": "Calcular Dias Sem Postar",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1200, 300],
      "parameters": {
        "jsCode": "const r = $input.item.json;\nconst clientData = $('Loop por Cliente').item.json;\n\n// Edge Function já retorna days_since_post e last_post_date prontos\nif (!r.has_posts || r.days_since_post === null) {\n  return [{ json: { skip: true, client_name: clientData.name } }];\n}\n\nreturn [{\n  json: {\n    skip: false,\n    days_since_post: r.days_since_post,\n    last_post_date: r.last_post_date,\n    client_id: clientData.id,\n    client_name: clientData.name,\n    client_company: clientData.company,\n    instagram_username: clientData.instagram_username,\n    whatsapp_group_id: clientData.whatsapp_group_id\n  }\n}];"
      }
    },
    {
      "id": "ig-node-06",
      "name": "Mais de 5 Dias?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1440, 300],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-skip",
              "leftValue": "={{ $json.skip }}",
              "rightValue": false,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            },
            {
              "id": "cond-days",
              "leftValue": "={{ $json.days_since_post }}",
              "rightValue": 5,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
