        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'claude-haiku-4-5-20251001', max_tokens: 400, messages: [{ role: 'user', content: 'Você é um consultor de marketing digital da agência RT Publicidade.\\n\\nCliente: ' + $json.client_company + '\\nInstagram: @' + $json.instagram_username.replace('@', '') + '\\nÚltima postagem: ' + $json.last_post_date + '\\nDias sem postar: ' + $json.days_since_post + '\\n\\nGere exatamente 3 sugestões práticas de conteúdo para Instagram para esse negócio.\\nFormato obrigatório:\\n1️⃣ *Tema* — descrição de 1 linha do que postar\\n2️⃣ *Tema* — descrição de 1 linha do que postar\\n3️⃣ *Tema* — descrição de 1 linha do que postar\\n\\nResponda APENAS com as 3 sugestões numeradas, sem texto adicional.' }] }) }}",
        "options": {}
      }
    },
    {
      "id": "ig-node-08",
      "name": "Montar Mensagens",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1920, 180],
      "parameters": {
        "jsCode": "const claudeSuggestions = $json.content[0].text.trim();\nconst clientData = $('Mais de 5 Dias?').item.json;\n\nconst whatsappMsg = `📸 *Olá, ${clientData.client_name}!*\\n\\nSua última postagem no Instagram foi em *${clientData.last_post_date}* — já faz *${clientData.days_since_post} dias* sem novidades por lá.\\n\\nIsso pode afetar seu alcance orgânico e fazer você perder seguidores que ainda não viraram clientes. 📉\\n\\nQue tal postar hoje? Aqui vão 3 ideias para você:\\n\\n${claudeSuggestions}\\n\\nQualquer dúvida, a gente te ajuda a criar! 🚀\\n_RT Publicidade_`;\n\nconst portalMsg = `Sua última postagem no Instagram foi em ${clientData.last_post_date} — já faz ${clientData.days_since_post} dias sem novidades.\\n\\nIsso pode afetar seu alcance orgânico. 📉\\n\\nSugestões de conteúdo para hoje:\\n\\n${claudeSuggestions}\\n\\nQualquer dúvida, fale com a gente! 🚀`;\n\nreturn [{\n  json: {\n    whatsapp_message: whatsappMsg,\n    portal_title: `📸 Sua última postagem foi há ${clientData.days_since_post} dias`,\n    portal_message: portalMsg,\n    client_id: clientData.client_id,\n    whatsapp_group_id: clientData.whatsapp_group_id\n  }\n}];"
      }
