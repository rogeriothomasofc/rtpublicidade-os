    {
      "id": "vd-node-05",
      "name": "Calcular Dias Sem Venda",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1200, 300],
      "parameters": {
        "jsCode": "// HTTP Request desempacota o array da RPC em itens individuais\n// raw[0].json = {created_at: \"...\"} (primeiro e único resultado da RPC LIMIT 1)\nconst raw = $input.all();\nconst ultimaVenda = raw.length > 0 && raw[0].json?.created_at ? raw[0].json.created_at : null;\nconst clientData = $('Loop por Cliente').item.json;\n\nlet daysSinceLastSale;\nlet lastSaleDate;\n\nif (!ultimaVenda) {\n  // Nunca registrou venda — considera como muitos dias\n  daysSinceLastSale = 999;\n  lastSaleDate = null;\n} else {\n  const lastDate = new Date(ultimaVenda);\n  const today = new Date();\n  daysSinceLastSale = Math.floor((today - lastDate) / (1000 * 60 * 60 * 24));\n  lastSaleDate = lastDate.toLocaleDateString('pt-BR', {\n    day: '2-digit',\n    month: '2-digit',\n    year: 'numeric'\n  });\n}\n\nreturn [{\n  json: {\n    skip: daysSinceLastSale < 2,\n    days_since_sale: daysSinceLastSale,\n    last_sale_date: lastSaleDate,\n    never_registered: !ultimaVenda,\n    client_id: clientData.id,\n    client_name: clientData.name,\n    client_company: clientData.company,\n    whatsapp_group_id: clientData.whatsapp_group_id\n  }\n}];"
      }
    },
    {
      "id": "vd-node-06",
      "name": "Mais de 2 Dias?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1440, 300],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-skip",
              "leftValue": "={{ $json.skip }}",
              "rightValue": false,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "vd-node-07",
      "name": "Gerar Mensagem com Claude",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1680, 180],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "SUBSTITUIR_ANTHROPIC_API_KEY"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'claude-haiku-4-5-20251001', max_tokens: 300, messages: [{ role: 'user', content: 'Você é um assistente da agência RT Publicidade.\\n\\nCliente: ' + $json.client_name + '\\nEmpresa: ' + ($json.client_company || $json.client_name) + '\\n' + ($json.never_registered ? 'Situação: nunca registrou uma venda no portal.' : 'Última venda registrada: ' + $json.last_sale_date + ' (' + $json.days_since_sale + ' dias atrás)') + '\\n\\nEscreva apenas o corpo da mensagem (2 a 3 frases), amigável e motivadora, lembrando o cliente de registrar suas vendas. Mencione que os dados são importantes para o relatório de desempenho. NÃO inclua saudação, NÃO inclua link, NÃO inclua assinatura. Responda APENAS com o texto do corpo.' }] }) }}",
        "options": {}
      }
    },
    {
      "id": "vd-node-08",
      "name": "Montar Mensagens",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1920, 180],
      "parameters": {
        "jsCode": "const claudeMsg = $json.content[0].text.trim();\nconst clientData = $('Mais de 2 Dias?').item.json;\n\nconst portalLink = 'https://agencia.rtpublicidade.com/';\n\nconst ultimaVendaInfo = clientData.never_registered\n  ? 'Você ainda não possui nenhuma venda registrada no painel.'\n  : `Último registro de venda no painel: *${clientData.last_sale_date}* (${clientData.days_since_sale} dias atrás).`;\n\nconst whatsappMsg = clientData.never_registered\n  ? `🛒 *Olá, ${clientData.client_name}!*\\n\\n${ultimaVendaInfo}\\n\\n${claudeMsg}\\n\\n👉 *Acesse o painel e registre suas vendas:*\\n${portalLink}\\n\\n_RT Publicidade_`\n  : `🛒 *Olá, ${clientData.client_name}!*\\n\\n${ultimaVendaInfo}\\n\\n${claudeMsg}\\n\\n👉 *Acesse o painel e registre suas vendas:*\\n${portalLink}\\n\\n_RT Publicidade_`;\n\nconst portalTitle = clientData.never_registered\n  ? '🛒 Você ainda não possui vendas registradas no painel'\n  : `🛒 Último registro de venda: ${clientData.last_sale_date} (${clientData.days_since_sale} dias atrás)`;\n\nconst portalMsg = clientData.never_registered\n  ? `Você ainda não possui nenhuma venda registrada no painel.\\n\\n${claudeMsg}\\n\\nMantenha seus dados atualizados para que seu relatório de desempenho fique completo! 📊\\n\\n👉 Acesse a aba Vendas para registrar.`\n  : `Último registro de venda: ${clientData.last_sale_date} (${clientData.days_since_sale} dias atrás).\\n\\n${claudeMsg}\\n\\nMantenha seus dados atualizados para que seu relatório fique completo! 📊\\n\\n👉 Acesse a aba Vendas para registrar.`;\n\nreturn [{\n  json: {\n    whatsapp_message: whatsappMsg,\n    portal_title: portalTitle,\n    portal_message: portalMsg,\n    client_id: clientData.client_id,\n    whatsapp_group_id: clientData.whatsapp_group_id\n  }\n}];"
      }
    },
