# ============================================================
# RT Publicidade OS — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no repositório.
# ============================================================

# Supabase — encontre no painel: Settings > API
VITE_SUPABASE_PROJECT_ID="seu-project-id-aqui"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key-aqui"
VITE_SUPABASE_URL="https://seu-project-id.supabase.co"

# Licença — gerada pelo dono do sistema para cada comprador
# Deixe em branco em instalações próprias (sem validação)
VITE_LICENSE_KEY=""

# Update Agent — gerado automaticamente pelo install.sh
# Permite atualizar o sistema pelo painel (Configurações → Sistema)
VITE_UPDATE_TOKEN=""

# ============================================================
# Integração WhatsApp (Evolution API + N8N)
# Configure estas variáveis no N8N como "Variables" globais
# ============================================================

# Evolution API — URL base da instância (ex: https://evolution.seudominio.com)
# EVOLUTION_API_URL=

# Evolution API — nome da instância criada no painel
# EVOLUTION_INSTANCE=

# Evolution API — chave de API (painel → Instance → API Key)
# EVOLUTION_API_KEY=

# JID do grupo da agência no WhatsApp (ex: 120363XXXXXX@g.us)
# Encontre rodando: GET /group/fetchAllGroups/{instance} na Evolution API
# WHATSAPP_GROUP_JID=

# Secret para autenticar chamadas do N8N na Edge Function
# Gere um valor aleatório e coloque aqui E na variável do Supabase
# WHATSAPP_WEBHOOK_SECRET=

# OpenAI API Key — usado apenas para transcrição de áudio (Whisper)
# Crie em: platform.openai.com/api-keys
# OPENAI_API_KEY=
